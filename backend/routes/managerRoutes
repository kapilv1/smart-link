const express = require("express");
const { connectDB } = require("../config/db");
const { toObjectId } = require("../utils/userUtils");
const getUserFromHeader = require("../middleware/authMiddleware");
const managerOnly = require("../middleware/managerMiddleware");

const router = express.Router();

router.use(getUserFromHeader);
router.use(managerOnly);

router.get("/users", async (_req, res) => {
  try {
    const db = await connectDB();

    const users = await db
      .collection("users")
      .find({}, { projection: { password: 0 } })
      .sort({ createdAt: -1 })
      .toArray();

    res.json(users);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

router.get("/users/:userId/profiles", async (req, res) => {
  try {
    const userId = toObjectId(req.params.userId);

    if (!userId) {
      return res.status(400).json({ error: "Invalid user ID" });
    }

    const db = await connectDB();

    const profiles = await db
      .collection("profiles")
      .find({ userId })
      .sort({ createdAt: -1 })
      .toArray();

    res.json(profiles);
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

router.put("/users/:userId/block", async (req, res) => {
  try {
    const userId = toObjectId(req.params.userId);

    if (!userId) {
      return res.status(400).json({ error: "Invalid user ID" });
    }

    const db = await connectDB();

    await db.collection("users").updateOne(
      { _id: userId, role: { $ne: "manager" } },
      {
        $set: {
          status: "blocked",
          updatedAt: new Date(),
        },
      }
    );

    res.json({ message: "User blocked" });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

router.put("/users/:userId/unblock", async (req, res) => {
  try {
    const userId = toObjectId(req.params.userId);

    if (!userId) {
      return res.status(400).json({ error: "Invalid user ID" });
    }

    const db = await connectDB();

    await db.collection("users").updateOne(
      { _id: userId },
